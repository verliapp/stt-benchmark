# Copy to .env.providers and fill in. run_cloud_engines.py loads this file.
# This file is gitignored. Never commit real keys.

# --- Plain API key providers ---
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
SONIOX_API_KEY=
SPEECHMATICS_API_KEY=
GLADIA_API_KEY=
ELEVENLABS_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
LEMONFOX_API_KEY=
REV_API_KEY=
GEMINI_API_KEY=   # LLM-based transcription (gemini-2.5-flash), added engine
XAI_API_KEY=      # xAI Grok Speech-to-Text (grok-stt), added engine
FISH_API_KEY=     # Fish Audio ASR (transcribe-1), added engine
CARTESIA_API_KEY= # Cartesia Ink STT (ink-whisper), added engine
INWORLD_API_KEY=  # Inworld Realtime STT-1, added engine
RESEMBLE_API_KEY= # Resemble STT (async), added engine

# --- Cloud accounts + storage ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus

GCP_PROJECT=
GCP_LOCATION=global
GOOGLE_APPLICATION_CREDENTIALS=

# --- Optional model overrides (defaults pinned to part-one's tested models) ---
